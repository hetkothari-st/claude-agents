{
  "colors": {
    "primary": "#0ea5e9",
    "primary-fg": "#001b29",
    "success": "#10b981",
    "danger":  "#ef4444",
    "warn":    "#f59e0b",
    "surface": {
      "0": "#0b0d10",
      "1": "#13171c",
      "2": "#1b2027",
      "3": "#252b33"
    },
    "border": "#1b2027",
